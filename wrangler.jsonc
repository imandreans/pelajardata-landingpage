{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pelajardata-landingpage",
  "compatibility_date": "2026-03-17",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "frontend/dist",
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "build": {
    "command": "npm install && npm run build",
    "cwd": "./frontend"
  }
  
}
